# URL of the Django GraphQL backend (default: http://localhost:8000)
VITE_BACKEND_URL=http://localhost:8000

# GraphQL endpoint path used by the frontend.
# In dev, requests go through Vite's proxy at /graphql, which forwards to VITE_BACKEND_URL.
# In production, set this to the absolute URL of your backend, e.g. https://api.example.com/graphql/
VITE_GRAPHQL_URL=/graphql/
